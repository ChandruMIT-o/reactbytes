rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated and is an admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Admins collection: only admins can read/write. A user can read their own document to verify status.
    match /admins/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if isAdmin();
    }

    // Raw events logging: anyone can write (create), only admins can read or delete
    match /raw_events/{event} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Page views logging: anyone can write (create), only admins can read or delete
    match /page_views/{view} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Aggregated daily stats: only admins can read/write
    match /daily_stats/{stat} {
      allow read, write: if isAdmin();
    }

    // Default rule: lock down everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
